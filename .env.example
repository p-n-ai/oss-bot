# OSS Bot Configuration
# Copy to .env and fill in your values

# --- Required (CLI) ---
OSS_REPO_PATH=./oss                         # Path to local OSS clone

# --- Required (Bot) ---
OSS_GITHUB_APP_ID=                          # GitHub App ID
OSS_GITHUB_PRIVATE_KEY_PATH=                # Path to GitHub App private key
OSS_GITHUB_WEBHOOK_SECRET=                  # GitHub App webhook secret

# --- Required (All) ---
OSS_AI_PROVIDER=ollama                      # openai | anthropic | ollama
OSS_AI_API_KEY=                             # Not needed for Ollama

# --- Required (OSS Repository) ---
OSS_REPO_OWNER=p-n-ai                       # Repository owner
OSS_REPO_NAME=oss                           # Repository name

# --- Reasoning Model (for bulk import, content merge) ---
OSS_AI_REASONING_PROVIDER=openrouter        # openrouter |openai | anthropic | ollama
OSS_AI_REASONING_API_KEY=                   # API key for reasoning provider
OSS_AI_REASONING_MODEL=deepseek/deepseek-r1 # Reasoning model to use

# --- Optional ---
OSS_AI_OLLAMA_URL=http://localhost:11434    # Ollama URL
OSS_AI_MODEL=                               # Override default model
OSS_WEB_PORT=3001                           # Web server port
OSS_BOT_PORT=8090                           # Bot server port
OSS_LOG_LEVEL=info                          # debug | info | warn | error
OSS_PROMPTS_DIR=./prompts                   # Prompts directory
OSS_TIKA_URL=                               # URL for Apache Tika server (optional, for server mode)
